{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lsam://schemas/base_event/v2",
  "title": "Base Event Envelope (v2)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "payload",
    "schema_hash"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[A-Z]+(?:_[A-Z0-9]+)+$"
    },
    "event_version": {
      "type": "integer",
      "minimum": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    },
    "schema_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
